{
  "info": {
    "name": "Test Optimized",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Xóa token cũ trước mỗi iteration để đảm bảo tính độc lập",
              "pm.environment.unset(\"token\");"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Login status check\", function () {",
              "    // Lấy giá trị từ cột expected_login_status trong file CSV",
              "    let expected = parseInt(pm.iterationData.get(\"expected_login_status\"));",
              "    pm.response.to.have.status(expected);",
              "});",
              "",
              "if (pm.response.code === 200) {",
              "    let json = pm.response.json();",
              "    pm.environment.set(\"token\", json.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{base_url}}/login"
      }
    },
    {
      "name": "Get Profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Profile status check\", function () {",
              "    // Lấy giá trị từ cột expected_status trong file CSV",
              "    let expected = parseInt(pm.iterationData.get(\"expected_status\"));",
              "    pm.response.to.have.status(expected);",
              "});",
              "",
              "if (pm.response.code === 200) {",
              "    pm.test(\"Profile data has sub property\", function () {",
              "        let json = pm.response.json();",
              "        // Dựa trên log trước đó, API dùng trường 'sub' thay vì 'username'",
              "        pm.expect(json).to.have.property('sub');",
              "    });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/profile"
      }
    }
  ]
}
